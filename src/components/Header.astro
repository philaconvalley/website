---
const navItems = [
  { name: 'About', href: '/about' },
  { name: 'Events', href: '/events' },
  { name: 'Projects', href: '/projects' },
  { name: 'Resources', href: '/resources' },
  { name: 'Join', href: '/join' },
  { name: 'Support', href: '/support' },
];

const currentPath = Astro.url.pathname;
---

<header class="sticky top-0 z-50 bg-brand-dark border-b-[3px] border-accent-400">
  <nav class="container-custom" x-data="{ mobileMenuOpen: false }">
    <div class="flex items-center justify-between h-[68px]">
      <!-- Logo -->
      <div class="flex-shrink-0">
        <a href="/" class="flex items-center space-x-3 group">
          <img
            src="/images/pink circle sunset logo.png"
            alt="PhilaCon Valley Logo"
            class="h-11 w-11 rounded-full drop-shadow-md"
          />
          <span class="text-lg font-display font-black text-accent-400 leading-tight">PhilaCon Valley</span>
        </a>
      </div>

      <!-- Desktop Navigation -->
      <div class="hidden md:block">
        <div class="flex items-center space-x-0.5">
          {
            navItems.map((item) => (
              <a
                href={item.href}
                class={`px-3 py-1.5 rounded-full text-sm font-display font-bold transition-colors ${
                  currentPath === item.href || currentPath.startsWith(item.href + '/')
                    ? 'bg-accent-400 text-white'
                    : 'text-primary-100 hover:bg-accent-400 hover:text-white'
                }`}
              >
                {item.name}
              </a>
            ))
          }
          <a
            href="/contact"
            class="ml-4 px-4 py-1.5 rounded-full bg-primary-300 text-brand-dark font-display font-black border-2 border-brand-dark hover:bg-primary-400 transition-colors"
          >
            Contact
          </a>
        </div>
      </div>

      <!-- Mobile menu button -->
      <div class="md:hidden">
        <button
          @click="mobileMenuOpen = !mobileMenuOpen"
          type="button"
          class="inline-flex items-center justify-center p-2 rounded-md text-primary-100 hover:text-white hover:bg-white/10 focus:outline-none focus:ring-2 focus:ring-inset focus:ring-accent-400"
          :aria-expanded="mobileMenuOpen.toString()"
        >
          <span class="sr-only">Open main menu</span>
          <!-- Hamburger icon -->
          <svg
            class="h-6 w-6"
            :class="{ 'hidden': mobileMenuOpen, 'block': !mobileMenuOpen }"
            fill="none"
            viewBox="0 0 24 24"
            stroke="currentColor"
          >
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16"></path>
          </svg>
          <!-- Close icon -->
          <svg
            class="h-6 w-6"
            :class="{ 'block': mobileMenuOpen, 'hidden': !mobileMenuOpen }"
            fill="none"
            viewBox="0 0 24 24"
            stroke="currentColor"
          >
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"></path>
          </svg>
        </button>
      </div>
    </div>

    <!-- Mobile menu -->
    <div x-show="mobileMenuOpen" x-cloak class="md:hidden bg-brand-dark" @click.away="mobileMenuOpen = false">
      <div class="px-2 pt-2 pb-3 space-y-1">
        {
          navItems.map((item) => (
            <a
              href={item.href}
              class={`block px-3 py-2 rounded-lg text-base font-display font-bold ${
                currentPath === item.href || currentPath.startsWith(item.href + '/')
                  ? 'bg-accent-400 text-white'
                  : 'text-primary-100 hover:bg-accent-400 hover:text-white'
              }`}
            >
              {item.name}
            </a>
          ))
        }
        <a
          href="/contact"
          class="block px-3 py-2 rounded-lg text-base font-display font-black bg-primary-300 text-brand-dark hover:bg-primary-400"
        >
          Contact
        </a>
      </div>
    </div>
  </nav>
</header>
