---
const navItems = [
  { name: 'About', href: '/about' },
  { name: 'Events', href: '/events' },
  { name: 'Projects', href: '/projects' },
  { name: 'Resources', href: '/resources' },
  { name: 'Blog', href: '/blog' },
  { name: 'Join', href: '/join' },
  { name: 'Support', href: '/support' },
];

const currentPath = Astro.url.pathname;
---

<header class="sticky top-0 z-50 bg-brand-dark border-b-2 border-accent-400/40">
  <nav class="container-custom" x-data="{ mobileMenuOpen: false }">
    <div class="flex items-center justify-between h-[68px]">
      <!-- Logo -->
      <div class="flex-shrink-0">
        <a href="/" class="flex items-center space-x-3 group">
          <img
            src="/images/philacon-valley-wordmark.webp"
            alt="PhilaCon Valley"
            class="h-10 md:h-11"
          />
        </a>
      </div>

      <!-- Desktop Navigation -->
      <div class="hidden md:block">
        <div
          class="relative flex items-center space-x-0.5"
          x-data="{ pos: { left: 0, width: 0 } }"
          x-init="const current = $el.querySelector('[aria-current=page]'); if (current) pos = { left: current.offsetLeft, width: current.offsetWidth }"
          @mouseleave="const current = $el.querySelector('[aria-current=page]'); if (current) pos = { left: current.offsetLeft, width: current.offsetWidth }"
        >
          <div
            x-cloak
            class="absolute inset-y-0 left-0 rounded-full bg-accent-400 transition-[transform,width] duration-300 ease-[cubic-bezier(0.16,1,0.3,1)] motion-reduce:transition-none"
            :style="`transform: translateX(${pos.left}px); width: ${pos.width}px;`"
          >
          </div>
          {
            navItems.map((item) => {
              const isCurrent =
                currentPath === item.href || currentPath.startsWith(item.href + '/');
              return (
                <a
                  href={item.href}
                  aria-current={isCurrent ? 'page' : undefined}
                  @mouseenter="pos = { left: $el.offsetLeft, width: $el.offsetWidth }"
                  class={`relative z-10 px-3 py-1.5 rounded-full text-sm font-display font-bold transition-colors ${
                    isCurrent ? 'text-white' : 'text-primary-100 hover:text-white'
                  }`}
                >
                  {item.name}
                </a>
              );
            })
          }
          <a
            href="/contact"
            class="relative z-10 ml-4 px-4 py-1.5 rounded-full bg-primary-300 text-brand-dark font-display font-black border-2 border-brand-dark hover:bg-primary-400 transition-colors"
          >
            Contact
          </a>
        </div>
      </div>

      <!-- Mobile menu button -->
      <div class="md:hidden">
        <button
          @click="mobileMenuOpen = !mobileMenuOpen"
          type="button"
          class="inline-flex items-center justify-center p-2 rounded-md text-primary-100 hover:text-white hover:bg-white/10 focus:outline-none focus:ring-2 focus:ring-inset focus:ring-accent-400"
          :aria-expanded="mobileMenuOpen.toString()"
        >
          <span class="sr-only">Open main menu</span>
          <!-- Hamburger icon -->
          <svg
            class="h-6 w-6"
            :class="{ 'hidden': mobileMenuOpen, 'block': !mobileMenuOpen }"
            fill="none"
            viewBox="0 0 24 24"
            stroke="currentColor"
          >
            <path
              stroke-linecap="round"
              stroke-linejoin="round"
              stroke-width="2"
              d="M4 6h16M4 12h16M4 18h16"></path>
          </svg>
          <!-- Close icon -->
          <svg
            class="h-6 w-6"
            :class="{ 'block': mobileMenuOpen, 'hidden': !mobileMenuOpen }"
            fill="none"
            viewBox="0 0 24 24"
            stroke="currentColor"
          >
            <path
              stroke-linecap="round"
              stroke-linejoin="round"
              stroke-width="2"
              d="M6 18L18 6M6 6l12 12"></path>
          </svg>
        </button>
      </div>
    </div>

    <!-- Mobile menu -->
    <div
      x-show="mobileMenuOpen"
      x-cloak
      x-transition:enter="transition ease-out duration-200 motion-reduce:duration-0"
      x-transition:enter-start="opacity-0 -translate-y-2"
      x-transition:enter-end="opacity-100 translate-y-0"
      x-transition:leave="transition ease-in duration-150 motion-reduce:duration-0"
      x-transition:leave-start="opacity-100 translate-y-0"
      x-transition:leave-end="opacity-0 -translate-y-2"
      class="md:hidden bg-brand-dark/90 backdrop-blur-lg border-t border-white/10"
      @click.away="mobileMenuOpen = false"
      @keydown.escape.window="mobileMenuOpen = false"
    >
      <div class="px-2 pt-2 pb-3 space-y-1">
        {
          navItems.map((item) => (
            <a
              href={item.href}
              class={`block px-3 py-2 rounded-lg text-base font-display font-bold ${
                currentPath === item.href || currentPath.startsWith(item.href + '/')
                  ? 'bg-accent-400 text-white'
                  : 'text-primary-100 hover:bg-accent-400 hover:text-white'
              }`}
            >
              {item.name}
            </a>
          ))
        }
        <a
          href="/contact"
          class="block px-3 py-2 rounded-lg text-base font-display font-black bg-primary-300 text-brand-dark hover:bg-primary-400"
        >
          Contact
        </a>
      </div>
    </div>
  </nav>
</header>
