---
interface Props {
  title: string;
  description: string;
  category: 'Workshop' | 'Tutorial' | 'Career' | 'Tool';
  level: 'Beginner' | 'Intermediate' | 'Advanced';
  author: string;
  tags: string[];
  slug: string;
}

const { title, description, category, level, author, tags, slug } = Astro.props;

const categoryConfig: Record<string, { color: string }> = {
  Workshop: { color: 'bg-brand-purple/15 text-brand-purple' },
  Tutorial: { color: 'bg-accent-100 text-accent-700' },
  Career: { color: 'bg-green-100 text-green-700' },
  Tool: { color: 'bg-primary-200 text-primary-800' },
};

const levelConfig: Record<string, { color: string; dots: number }> = {
  Beginner: { color: 'text-green-500', dots: 1 },
  Intermediate: { color: 'text-primary-500', dots: 2 },
  Advanced: { color: 'text-accent-600', dots: 3 },
};

const cat = categoryConfig[category] || categoryConfig.Tutorial;
const lvl = levelConfig[level] || levelConfig.Beginner;
---

<a href={`/resources/${slug}`} class="card p-6 h-full flex flex-col group">
  <div class="flex items-center gap-2 mb-3">
    <span class={`px-2.5 py-1 text-xs font-display font-bold rounded-full ${cat.color}`}>
      {category}
    </span>
    <span class="flex items-center gap-1 text-xs font-display font-bold text-brand-dark/50">
      {
        Array.from({ length: 3 }).map((_, i) => (
          <span
            class={`inline-block w-2 h-2 rounded-full ${i < lvl.dots ? lvl.color.replace('text-', 'bg-') : 'bg-brand-dark/10'}`}
          />
        ))
      }
      {level}
    </span>
  </div>

  <h3
    class="text-lg font-display font-bold text-brand-dark group-hover:text-accent-600 transition-colors mb-2"
  >
    {title}
  </h3>

  <p class="text-sm text-brand-dark/60 leading-relaxed mb-4 flex-1">{description}</p>

  <div class="flex flex-wrap gap-1.5 mb-4">
    {
      tags.map((tag) => (
        <span class="px-2 py-0.5 bg-primary-100 text-primary-800 text-xs font-display font-bold rounded-full">
          #{tag}
        </span>
      ))
    }
  </div>

  <div class="flex items-center justify-between mt-auto pt-3 border-t border-brand-dark/5">
    <span class="text-sm text-brand-dark/40">By {author}</span>
    <span
      class="text-sm font-display font-bold text-accent-600 group-hover:text-accent-700 transition-colors"
    >
      Read More →
    </span>
  </div>
</a>
